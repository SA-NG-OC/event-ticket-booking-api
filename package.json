{
  "name": "event-ticket-booking-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:worker": "node dist/worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/infrastructure/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "studio:test": "cross-env DATABASE_URL=postgresql://concert_user:concert_pass@localhost:5434/concert_test_db drizzle-kit studio --port 4984",
    "db:migrate:test": "cross-env DATABASE_URL=postgresql://concert_user:concert_pass@localhost:5434/concert_test_db drizzle-kit migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}